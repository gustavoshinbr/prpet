# ===== Supabase =====
# Crie um projeto em https://supabase.com e cole as credenciais
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_AQUI
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_AQUI

# ===== Asaas =====
# Crie a conta em https://www.asaas.com -> Integrações -> Gerar Chave de API
# Para ambiente de produção use https://api.asaas.com/v3
# Para sandbox use https://sandbox.asaas.com/api/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=SUA_CHAVE_ASAAS_AQUI
ASAAS_WEBHOOK_TOKEN=DEFINA_UM_TOKEN_QUALQUER_AQUI

# ===== App =====
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SUBSCRIPTION_PRICE=80.00
